<Page x:Class="Kurs_Bank.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource DarkBgBrush}">

    <ScrollViewer Padding="30">
        <StackPanel>

            <TextBlock Text="Личный кабинет"
                       Foreground="{StaticResource TextLightBrush}"
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- КАРТОЧКА ПРОФИЛЯ -->
            <Border Background="{StaticResource CardBgBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="64" Height="64"
                            CornerRadius="32" Background="{StaticResource PrimaryBrush}"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="AvatarText"
                                   Foreground="White" FontSize="24" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="FullNameText"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="PassportText"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="13" Margin="0,4,0,0"/>
                        <TextBlock x:Name="PhoneText"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="13" Margin="0,4,0,0"/>
                        <TextBlock x:Name="EmailText"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ДЕТАЛИ -->
            <Border Background="{StaticResource CardBgBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Личные данные"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата рождения"
                                   Foreground="#A78BFA" VerticalAlignment="Center"/>
                        <TextBlock x:Name="BirthDateText" Grid.Row="0" Grid.Column="1"
                                   Foreground="{StaticResource TextLightBrush}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Город"
                                   Foreground="#A78BFA" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CityText" Grid.Row="1" Grid.Column="1"
                                   Foreground="{StaticResource TextLightBrush}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Улица"
                                   Foreground="#A78BFA" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StreetText" Grid.Row="2" Grid.Column="1"
                                   Foreground="{StaticResource TextLightBrush}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дом"
                                   Foreground="#A78BFA" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HouseText" Grid.Row="3" Grid.Column="1"
                                   Foreground="{StaticResource TextLightBrush}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Логин"
                                   Foreground="#A78BFA" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LoginText" Grid.Row="4" Grid.Column="1"
                                   Foreground="{StaticResource TextLightBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- СМЕНА ПАРОЛЯ -->
            <Border Background="{StaticResource CardBgBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Сменить пароль"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Текущий пароль"
                                       Foreground="{StaticResource TextLightBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="OldPasswordBox"
                                         Style="{StaticResource ModernPasswordBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Новый пароль"
                                       Foreground="{StaticResource TextLightBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="NewPasswordBox"
                                         Style="{StaticResource ModernPasswordBox}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Сохранить"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,8" VerticalAlignment="Bottom"
                                Click="ChangePassword_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ЗАКРЫТЫЕ СЧЕТА -->
            <Border Background="{StaticResource CardBgBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Закрытые счета"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <ItemsControl x:Name="ClosedAccountsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2D1F5E" CornerRadius="8"
                                        Padding="16,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextLightBrush}">
                                                <Run Text="Счёт №"/>
                                                <Run Text="{Binding AccountID}"/>
                                                <Run Text=" — "/>
                                                <Run Text="{Binding AccountType}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="#A78BFA" FontSize="11">
                                                <Run Text="Закрыт: "/>
                                                <Run Text="{Binding CloseDate, StringFormat=dd.MM.yyyy}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Удалить"
                                                Tag="{Binding AccountID}"
                                                Click="DeleteAccount_Click"
                                                Padding="10,6"
                                                Background="#FF6B6B" Foreground="White"
                                                BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="NoClosedAccountsText"
                               Text="Нет закрытых счетов"
                               Foreground="#A78BFA" FontSize="13"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>