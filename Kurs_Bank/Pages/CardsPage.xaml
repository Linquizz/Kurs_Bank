<Page x:Class="Kurs_Bank.Pages.CardsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Kurs_Bank.Helpers"
      Background="{StaticResource DarkBgBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Мои карты"
                   Foreground="{StaticResource TextLightBrush}"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="CardsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="300" CornerRadius="16"
                                Margin="0,0,20,20" Padding="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5C3FBE" Offset="0"/>
                                    <GradientStop Color="#A78BFA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="{Binding CardType, Mode=OneWay}"
                                               Foreground="White" FontSize="12" Opacity="0.8"/>
                                    <TextBlock Text="{Binding Status, Mode=OneWay}"
                                               Foreground="White" FontSize="12"
                                               HorizontalAlignment="Right" Opacity="0.8"/>
                                </Grid>

                                <TextBlock Text="{Binding FormattedCardNumber, Mode=OneWay}"
                                           Foreground="White" FontSize="18"
                                           FontWeight="Bold" Margin="0,20,0,0"
                                           FontFamily="Courier New"/>

                                <TextBlock Foreground="White" FontSize="11"
                                           Opacity="0.7" Margin="0,12,0,2">
                                    БАЛАНС СЧЁТА
                                </TextBlock>
                                <TextBlock Foreground="White" FontSize="20" FontWeight="Bold">
                                    <Run Text="{Binding Account.Balance, StringFormat={}{0:N2}, Mode=OneWay}"/>
                                    <Run Text=" ₽"/>
                                </TextBlock>

                                <Grid Margin="0,12,0,12">
                                    <StackPanel HorizontalAlignment="Left">
                                        <TextBlock Text="ДЕЙСТВУЕТ ДО" Foreground="White"
                                                   FontSize="9" Opacity="0.7"/>
                                        <TextBlock Text="{Binding ExpiryDate, StringFormat=MM/yy, Mode=OneWay}"
                                                   Foreground="White" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Заблокировать"
                                            Tag="{Binding CardNumber, Mode=OneWay}"
                                            Click="BlockCard_Click"
                                            Padding="10,6" Margin="0,0,8,0"
                                            Background="#FF6B6B" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Visibility="{Binding IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="Активировать"
                                            Tag="{Binding CardNumber, Mode=OneWay}"
                                            Click="ActivateCard_Click"
                                            Padding="10,6" Margin="0,0,8,0"
                                            Background="#6BCB77" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Visibility="{Binding IsBlocked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="Удалить"
                                            Tag="{Binding CardNumber, Mode=OneWay}"
                                            Click="DeleteCard_Click"
                                            Padding="10,6"
                                            Background="#8B0000" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Visibility="{Binding IsBlocked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource CardBgBrush}"
                CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="Выпустить новую карту"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Счёт" Foreground="{StaticResource TextLightBrush}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CardAccountCombo"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemTemplate="{StaticResource AccountComboTemplate}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Тип карты" Foreground="{StaticResource TextLightBrush}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CardTypeCombo"
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="Дебетовая"/>
                            <ComboBoxItem Content="Сберегательная"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Выпустить"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8" VerticalAlignment="Bottom"
                            Click="IssueCard_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>