<Window x:Class="Kurs_Bank.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Банк — Регистрация" Height="700" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource DarkBgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="50,30">

            <TextBlock Text="Регистрация"
                       Foreground="{StaticResource TextLightBrush}"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <TextBlock Text="Создайте новый аккаунт"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="13" HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <TextBlock Text="Номер паспорта" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="PassportBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Фамилия" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="LastNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Имя" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="FirstNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Отчество" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="MiddleNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Дата рождения (дд.мм.гггг)" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="BirthDateBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Телефон" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="PhoneBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Город" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="CityBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Улица" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="StreetBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Дом" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="HouseBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>

            <Separator Background="#5C3FBE" Margin="0,0,0,20"/>

            <TextBlock Text="Логин" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="LoginBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            <TextBlock Text="Пароль" Foreground="{StaticResource TextLightBrush}" FontSize="12" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,20"/>

            <TextBlock x:Name="ErrorText" Foreground="#FF6B6B"
                       FontSize="12" HorizontalAlignment="Center"
                       Margin="0,0,0,12" Visibility="Collapsed" TextWrapping="Wrap"/>

            <Button Content="Зарегистрироваться" Style="{StaticResource PrimaryButton}"
                    Click="RegisterButton_Click"/>

            <TextBlock HorizontalAlignment="Center" Margin="0,16,0,30">
                <Run Foreground="{StaticResource AccentBrush}" Text="Уже есть аккаунт? "/>
                <Run Foreground="White" Text="Войти"
                     MouseLeftButtonDown="GoToLogin_Click"
                     TextDecorations="Underline" Cursor="Hand"/>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</Window>