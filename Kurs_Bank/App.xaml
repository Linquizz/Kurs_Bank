<Application x:Class="Kurs_Bank.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Kurs_Bank.Helpers"
             StartupUri="Pages/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Color x:Key="PrimaryColor">#5C3FBE</Color>
            <Color x:Key="SecondaryColor">#7B5EA7</Color>
            <Color x:Key="AccentColor">#A78BFA</Color>
            <Color x:Key="DarkBg">#1A1035</Color>
            <Color x:Key="CardBg">#261850</Color>
            <Color x:Key="TextLight">#F0EAFB</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="DarkBgBrush" Color="{StaticResource DarkBg}"/>
            <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}"/>
            <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}"/>

            <DataTemplate x:Key="AccountComboTemplate">
                <TextBlock Foreground="White">
                    <Run Text="Счёт №"/>
                    <Run Text="{Binding AccountID}"/>
                    <Run Text=" — "/>
                    <Run Text="{Binding Balance, StringFormat={}{0:N2}}"/>
                    <Run Text=" ₽ ("/>
                    <Run Text="{Binding AccountType}"/>
                    <Run Text=")"/>
                </TextBlock>
            </DataTemplate>

            <DataTemplate x:Key="CardComboTemplate">
                <TextBlock Foreground="White">
        <Run Text="{Binding FormattedCardNumber, Mode=OneWay}"/>
        <Run Text=" ("/>
        <Run Text="{Binding CardType, Mode=OneWay}"/>
        <Run Text=") — "/>
        <Run Text="{Binding Account.Balance, StringFormat={}{0:N2}, Mode=OneWay}"/>
        <Run Text=" ₽"/>
                </TextBlock>
            </DataTemplate>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="0,12"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#3D2A6E"/>
                                    <Setter Property="Foreground" Value="#6B5A8E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3D2A6E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="#2D1F5E"/>
                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                <Setter Property="BorderBrush" Value="#5C3FBE"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CaretBrush" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
                <Setter Property="Background" Value="#2D1F5E"/>
                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                <Setter Property="BorderBrush" Value="#5C3FBE"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="#2D1F5E"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#5C3FBE"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <Grid>
                                        <ContentPresenter x:Name="ContentSite"
                                                          IsHitTestVisible="False"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          Margin="10,8,30,8"
                                                          VerticalAlignment="Center"/>
                                        <TextBlock x:Name="PlaceholderText"
                                                   Text="Выберите..."
                                                   Foreground="#A78BFA"
                                                   Margin="10,8,30,8"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"
                                                   Visibility="Collapsed"/>
                                        <ToggleButton BorderThickness="0"
                                                      Background="Transparent"
                                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Focusable="False"
                                                      ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="30"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="Transparent"/>
                                                            <TextBlock Grid.Column="1" Text="▾"
                                                                       Foreground="#A78BFA"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                    </Grid>
                                </Border>
                                <Popup x:Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Grid MinWidth="{TemplateBinding ActualWidth}"
                                          MaxHeight="200">
                                        <Border Background="#2D1F5E"
                                                BorderBrush="#5C3FBE"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <ScrollViewer>
                                                <StackPanel IsItemsHost="True"
                                                            KeyboardNavigation.DirectionalNavigation="Contained"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="SelectedItem" Value="{x:Null}">
                                    <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#2D1F5E"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#5C3FBE"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#7B5EA7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>