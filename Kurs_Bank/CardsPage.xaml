<Page x:Class="Kurs_Bank.Views.Pages.CardsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource DarkBgBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Мои карты"
                   Foreground="{StaticResource TextLightBrush}"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <ItemsControl Grid.Row="1" x:Name="CardsList">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="280" Height="160" CornerRadius="16"
                            Margin="0,0,20,20" Padding="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5C3FBE" Offset="0"/>
                                <GradientStop Color="#A78BFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="{Binding CardType}"
                                       Foreground="White" FontSize="12" Opacity="0.8"/>
                            <TextBlock Text="{Binding CardNumber}"
                                       Foreground="White" FontSize="16"
                                       FontWeight="Bold" Margin="0,16,0,0"/>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ДЕЙСТВУЕТ ДО" Foreground="White"
                                               FontSize="9" Opacity="0.7"/>
                                    <TextBlock Text="{Binding ExpiryDate, StringFormat=MM/yy}"
                                               Foreground="White" FontSize="13"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Status}"
                                           Foreground="White" FontSize="12"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="2" Background="{StaticResource CardBgBrush}"
                CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="Выпустить новую карту"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Счёт" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CardAccountCombo"
                                  Background="#2D1F5E" Foreground="{StaticResource TextLightBrush}"
                                  BorderBrush="#5C3FBE"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Тип карты" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CardTypeCombo"
                                  Background="#2D1F5E" Foreground="{StaticResource TextLightBrush}"
                                  BorderBrush="#5C3FBE">
                            <ComboBoxItem Content="Дебетовая"/>
                            <ComboBoxItem Content="Кредитная"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Выпустить"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8" VerticalAlignment="Bottom"
                            Click="IssueCard_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>