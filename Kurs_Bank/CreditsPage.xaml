<Page x:Class="Kurs_Bank.Views.Pages.CreditsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource DarkBgBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Кредиты"
                   Foreground="{StaticResource TextLightBrush}"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <ItemsControl Grid.Row="1" x:Name="CreditsList" Margin="0,0,0,20">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource CardBgBrush}"
                            CornerRadius="12" Padding="20" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Сумма" Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                                <TextBlock Foreground="{StaticResource TextLightBrush}" FontSize="18" FontWeight="Bold">
                                    <Run Text="{Binding Amount}"/><Run Text=" ₽"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ставка" Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                                <TextBlock Foreground="{StaticResource TextLightBrush}" FontSize="18" FontWeight="Bold">
                                    <Run Text="{Binding InterestRate}"/><Run Text="%"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Статус" Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding Status}"
                                           Foreground="{StaticResource TextLightBrush}"
                                           FontSize="16"/>
                            </StackPanel>
                            <Button Grid.Column="3" Content="Оплатить"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="14,8" VerticalAlignment="Center"
                                    Tag="{Binding CreditID}"
                                    Click="PayCredit_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="2" Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="Оформить кредит" Foreground="{StaticResource AccentBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Сумма" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="CreditAmountBox" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Срок (месяцев)" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="CreditTermBox" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Счёт для выплат" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CreditAccountCombo"
                                  Background="#2D1F5E" Foreground="{StaticResource TextLightBrush}"
                                  BorderBrush="#5C3FBE"/>
                    </StackPanel>
                    <Button Grid.Column="3" Content="Оформить"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8" VerticalAlignment="Bottom"
                            Click="ApplyCredit_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>